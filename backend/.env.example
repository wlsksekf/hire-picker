# ======================================================
# 백엔드 환경변수 예제 파일
# ======================================================
# 이 파일을 복사하여 .env 파일을 만든 후, 아래 값들을 자신의 로컬 환경에 맞게 채워주세요.

# 1. work24 API 인증키
work24_key=

# 2. 데이터베이스 연결 정보
# 로컬 PC에 설치된 MySQL 서버의 정보와 일치해야 합니다.
DB_URL=jdbc:mysql://localhost:3306/hirepicker
DB_USERNAME=root
DB_PASSWORD=your_password
