# =================================================
# Backend Environment Variables
# =================================================
# 데이터베이스 연결 정보 (로컬 개발용)
# 예시: 로컬 PC에 설치된 MySQL에 데이터베이스를 사용하는 경우
DB_URL=jdbc:mysql://localhost:3306/resume?useSSL=false&serverTimezone=UTC&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_local_db_password

# =================================================
# CI/CD 및 Docker 관련 변수 (로컬 실행 시에는 필수는 아님)
# =================================================
DOCKER_USERNAME=your_dockerhub_username
BACKEND_IMAGE=hirepicker-backend
FRONTEND_IMAGE=hirepicker-frontend
GITHUB_SHA=local